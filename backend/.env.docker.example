# CareConnect Backend Docker environment
# Copy to `.env.docker` and fill in real values. NEVER commit `.env.docker`.
#
# This file is intentionally backend-only. Docker Compose also uses it for the
# local PostgreSQL container, so DB_* values must match the Postgres settings.

# --- Runtime ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# --- PostgreSQL ---
# The backend connects using these DB_* vars (host is the Compose service name).
DB_HOST=postgres
DB_PORT=5432
POSTGRES_HOST_PORT=5432
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=
# The Postgres container is initialized from these POSTGRES_* vars (the official
# image reads only this naming). Keep them IN SYNC with DB_NAME/DB_USER/DB_PASSWORD
# above — they describe the same database. Having them here lets Compose configure
# Postgres via `env_file` with no `--env-file` interpolation flags.
POSTGRES_DB=careconnect
POSTGRES_USER=careconnect
POSTGRES_PASSWORD=

# --- Firebase Admin (service account) ---
# From the Firebase service-account JSON. Keep the private key as a single line with \n escapes.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_STORAGE_BUCKET=

# --- Optional disposable dev seed ---
# Create these Firebase Auth users manually, then paste their Firebase UID values
# here before first initializing the Docker Postgres volume. Demo data is loaded
# only when ENABLE_DEV_SEED=true, NODE_ENV=development, and every UID is filled.
ENABLE_DEV_SEED=false
DEV_SEED_FIREBASE_UID_CUSTOMER_DEMO=
DEV_SEED_FIREBASE_UID_SITTER_BABY=
DEV_SEED_FIREBASE_UID_SITTER_PET=
DEV_SEED_FIREBASE_UID_SITTER_BOTH=
DEV_SEED_FIREBASE_UID_SITTER_UNVERIFIED=

# --- Whish Money payments ---
# In production all four WHISH_* vars are REQUIRED (the backend fails fast at
# startup if any is missing). Outside production (NODE_ENV=development|test) they
# are OPTIONAL: when left blank the backend substitutes dev-only placeholders so
# the stack boots without a Whish merchant account. Payments won't actually work
# in that mode, but nothing can be falsely confirmed (see config/env.ts).
WHISH_API_URL=
WHISH_CHANNEL=
WHISH_SECRET=
WHISH_WEBSITE_URL=
PAYMENT_CURRENCY=USD
