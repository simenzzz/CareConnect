# CareConnect Backend Docker environment
# Copy to `.env.docker` and fill in real values. NEVER commit `.env.docker`.
#
# This file is intentionally backend-only. Docker Compose also uses it for the
# local PostgreSQL container, so DB_* values must match the Postgres settings.

# --- Runtime ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# --- PostgreSQL (inside Docker, host is the Compose service name) ---
DB_HOST=postgres
DB_PORT=5432
POSTGRES_HOST_PORT=5432
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=

# --- Firebase Admin (service account) ---
# From the Firebase service-account JSON. Keep the private key as a single line with \n escapes.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# --- Whish Money payments ---
WHISH_API_URL=
WHISH_CHANNEL=
WHISH_SECRET=
WHISH_WEBSITE_URL=
PAYMENT_CURRENCY=USD
